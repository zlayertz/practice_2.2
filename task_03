import json
import requests
courses = {}
groups = {}
try:
    with open('save.json', 'r', encoding='utf-8') as file:
        groups = json.load(file)
except:
    groups = {}
def obnovit_courses():
    global courses
    try:
        otvet_servera = requests.get('https://www.cbr-xml-daily.ru/daily_json.js')
        data_json = otvet_servera.json()
        courses = data_json['Valute']
    except:
        print('Не могу получить курсы')
def pokazat_vse():
    print('\n\t\t\tВсе валюты')
    for cod_valute in courses:
        valute_name = courses[cod_valute]['Name']
        price = courses[cod_valute]['Value']
        print(f'{cod_valute} - {valute_name}: {price} руб.')
def nayti_valutu():
    input_cod = input('Код валюты: ')
    input_cod = input_cod.upper()
    if input_cod in courses:
        print(f'{input_cod} стоит {courses[input_cod]['Value']} рублей')
    else:
        print('Нет такой валюты')
def sozdat_gruppu():
    new_group = input('Название группы: ')
    if new_group in groups:
        print('Такая группа уже есть')
    else:
        groups[new_group] = []
        sohranit_gruppi()
        print(f'Группа "{new_group}" создана')
def pokazat_vse_gruppi():
    if len(groups) == 0:
        print('Нет ни одной группы')
        return
    print('\n\tСуществующие группы')
    for new_group in groups:
        print(f'\nГруппа: {new_group}')
        if len(groups[new_group]) == 0:
            print('\t(пусто)')
        else:
            for cod_valute in groups[new_group]:
                if cod_valute in courses:
                    print(f'  {cod_valute} - {courses[cod_valute]['Value']} руб.')
                else:
                    print(f'  {cod_valute} - (нет данных)')
def dobavit_v_gruppu():
    new_group = input('Введите название группы: ')
    if new_group not in groups:
        print('Нет такой группы')
        return
    input_cod = input('Введите код валюты: ')
    input_cod = input_cod.upper()
    if input_cod not in courses:
        print('Нет такой валюты')
        return
    if input_cod in groups[new_group]:
        print('Такая валюта уже есть в группе')
    else:
        groups[new_group].append(input_cod)
        sohranit_gruppi()
        print(f'Добавил {input_cod} в группу {new_group}')
def udalit_iz_gruppi():
    new_group = input('Введите название группы: ')
    if new_group not in groups:
        print('Нет такой группы')
        return
    if len(groups[new_group]) == 0:
        print('В группе нет валют')
        return
    print('Валюты в группе:')
    for index_valute, cod_valute in enumerate(groups[new_group]):
        print(f'{index_valute + 1}. {cod_valute}')
    input_user = input('Что удалить: ')
    if input_user.isdigit():
        number = int(input_user) - 1
        if number < len(groups[new_group]):
            delete = groups[new_group].pop(number)
            sohranit_gruppi()
            print(f'Удалено {delete}')
        else:
            print('Неверный номер')
    else:
        input_user = input_user.upper()
        if input_user in groups[new_group]:
            groups[new_group].remove(input_user)
            sohranit_gruppi()
            print(f'Удалил {input_user}')
        else:
            print('Нет такой валюты в группе')
def sohranit_gruppi():
    with open('save.json', 'w', encoding='utf-8') as file:
        json.dump(groups, file, ensure_ascii=False, indent=2)
obnovit_courses()
while True:
    print('\nВыбор функции')
    print('\n1 - Показать все валюты')
    print('2 - Найти валюту')
    print('3 - Создать новую группу')
    print('4 - Показать все группы')
    print('5 - Добавить валюту в группу')
    print('6 - Удалить валюту из группы')
    print('7 - Обновить курсы')
    print('8 - Выйти')
    vybor_menu = input('\nВыбранная:')
    if vybor_menu == '1':
        pokazat_vse()
    elif vybor_menu == '2':
        nayti_valutu()
    elif vybor_menu == '3':
        sozdat_gruppu()
    elif vybor_menu == '4':
        pokazat_vse_gruppi()
    elif vybor_menu == '5':
        dobavit_v_gruppu()
    elif vybor_menu == '6':
        udalit_iz_gruppi()
    elif vybor_menu == '7':
        obnovit_courses()
    elif vybor_menu == '8':
        break
    else:
        print('Такого пункта нет')
