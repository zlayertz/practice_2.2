import psutil
import time
while True:
    cpu = psutil.cpu_percent(interval=1)
    ram = psutil.virtual_memory()
    disk = psutil.disk_usage('.')
    print('\tСИСТЕМНЫЙ МОНИТОР')
    print(f'CPU: {cpu}%')
    print(f'RAM: {ram.percent}%  ({ram.used // (1024 ** 3)}/{ram.total // (1024 ** 3)} ГБ)')
    print(f'Диск: {disk.percent}%  ({disk.used // (1024 ** 3)}/{disk.total // (1024 ** 3)} ГБ)')
    print('===' * 8)
    time.sleep(4)
